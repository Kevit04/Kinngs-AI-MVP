            <!-- Social Channels -->
            <div class="flex items-center gap-4 text-slate-400">
                <a href="#" class="hover:text-kingGold-400 text-lg transition-colors"><i class="fa-brands fa-x-twitter"></i></a>
                <a href="#" class="hover:text-kingGold-400 text-lg transition-colors"><i class="fa-brands fa-discord"></i></a>
                <a href="#" class="hover:text-kingGold-400 text-lg transition-colors"><i class="fa-brands fa-telegram"></i></a>
                <a href="#" class="hover:text-kingGold-400 text-lg transition-colors"><i class="fa-brands fa-github"></i></a>
