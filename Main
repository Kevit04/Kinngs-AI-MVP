    <!-- INTERACTIVE JAVASCRIPT STATE ENGINE -->
    <script>
        // System State parameters
        let state = {
            currentTab: 'landing',
            onboardingStep: 1,
            user: {
                email: '',
                walletAddress: '',
                username: '',
                referralCode: '',
                xConnected: false,
                discordConnected: false,
                telegramConnected: false
            },
            walletConnected: false,
            balance: 0,
            boosterMultiplier: 1.0,
            referralsCount: 0,
            completedQuests: {
                twitter: false,
                discord: false,
                zealy: false
            },
            droneState: {
                battery: 87,
                altitude: 12.4,
                status: 'PATROLLING',
                logs: [
                    "[SYSTEM]: Initializing secure Drone console handshake...",
                    "[SECURE]: Handshake complete. AES-256 validation verified.",
                    "[GPS]: Location synced with physical coordinates node ID KB-001."
                ]
            }
        };

        // DOM elements initialization
        window.onload = function() {
            updateTimestamp();
            setInterval(updateTimestamp, 1000);
            
            // Populate initial state to view components
            updateReferralCodePreview();
            
            // Start mock telemetry update timers
            setInterval(simulateDroneTelemetry, 8000);
        };

        // Navigation state machine
        function navigate(tabName) {
            // Hide all tabs
            document.getElementById('view-landing').classList.add('hidden');
            document.getElementById('view-onboarding').classList.add('hidden');
            document.getElementById('view-dashboard').classList.add('hidden');

            // Show active tab
            if (tabName === 'landing') {
                document.getElementById('view-landing').classList.remove('hidden');
            } else if (tabName === 'onboarding') {
                document.getElementById('view-onboarding').classList.remove('hidden');
                updateOnboardingView();
            } else if (tabName === 'dashboard') {
                document.getElementById('view-dashboard').classList.remove('hidden');
                updateDashboardView();
            }
            state.currentTab = tabName;
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // Onboarding navigation controls
        function startOnboarding() {
            if (state.walletConnected && state.user.username) {
                // Already authenticated and synced
                navigate('dashboard');
                showToast("Welcome Back!", "Control Chamber synchronized successfully.", "gold");
            } else {
                navigate('onboarding');
            }
        }

        function updateOnboardingView() {
            // Hide all step contents
            for (let i = 1; i <= 5; i++) {
                document.getElementById(`step-content-${i}`).classList.add('hidden');
                // Reset dots classes
                const dot = document.getElementById(`step-dot-${i}`);
                if (dot) {
                    dot.className = "h-8 w-8 rounded-full border-2 border-hiveDark-700 bg-hiveDark-900 flex items-center justify-center font-mono text-xs font-bold text-slate-500 z-10";
                }
            }

            // Show current step content
            document.getElementById(`step-content-${state.onboardingStep}`).classList.remove('hidden');

            // Update dots up to current step
            for (let i = 1; i <= state.onboardingStep; i++) {
                const dot = document.getElementById(`step-dot-${i}`);
                if (dot) {
                    if (i === state.onboardingStep) {
                        dot.className = "h-8 w-8 rounded-full border-2 border-kingGold-500 bg-hiveDark-900 flex items-center justify-center font-mono text-xs font-bold text-kingGold-400 z-10 shadow-goldGlow";
                    } else {
                        dot.className = "h-8 w-8 rounded-full border-2 border-emerald-500 bg-hiveDark-900 flex items-center justify-center font-mono text-xs font-bold text-emerald-400 z-10";
                    }
                }
            }

            // Update indicators connector lines
            for (let i = 1; i <= 4; i++) {
                const bar = document.getElementById(`ob-bar-${i}`);
                if (bar) {
                    if (i < state.onboardingStep) {
                        bar.className = "h-1 flex-grow bg-kingGold-500 transition-colors duration-300";
                    } else {
                        bar.className = "h-1 flex-grow bg-hiveDark-700 transition-colors duration-300";
                    }
                }
            }

            // Back button control
            const backBtn = document.getElementById('ob-btn-back');
            if (state.onboardingStep === 1) {
                backBtn.classList.add('hidden');
            } else {
                backBtn.classList.remove('hidden');
            }

            // Next button text
            const nextBtn = document.getElementById('ob-btn-next');
            if (state.onboardingStep === 4) {
                nextBtn.innerHTML = `Establish Sync <i class="fa-solid fa-cube ml-2"></i>`;
            } else if (state.onboardingStep === 5) {
                document.getElementById('onboarding-nav-btns').classList.add('hidden');
                // Trigger auto-completing loader simulation
                setTimeout(runVaultInitialization, 500);
            } else {
                nextBtn.innerHTML = `Forward <i class="fa-solid fa-arrow-right ml-2"></i>`;
            }
        }

        function nextStep() {
            // Validation requirements per step
            if (state.onboardingStep === 1) {
                const email = document.getElementById('ob-email').value;
                const pass = document.getElementById('ob-pass').value;
                if (!email || !email.includes('@')) {
                    showToast("Validation Warning", "Please enter a valid node email address.", "blue");
                    return;
                }
                if (!pass || pass.length < 5) {
                    showToast("Validation Warning", "Access Passphrase must be at least 5 characters.", "blue");
                    return;
                }
                state.user.email = email;
            }

            if (state.onboardingStep === 2) {
                if (!state.walletConnected) {
                    showToast("Ecosystem Rule", "Please connect a Web3 wallet address to proceed.", "gold");
                    return;
                }
            }

            if (state.onboardingStep === 3) {
                if (!state.user.xConnected && !state.user.discordConnected && !state.user.telegramConnected) {
                    showToast("Community Onboarding", "Connect at least one social pipeline to continue.", "blue");
                    return;
                }
            }

            if (state.onboardingStep === 4) {
                const username = document.getElementById('ob-username').value.trim();
                if (!username || username.length < 3) {
                    showToast("Validation Warning", "Ecosystem username must contain at least 3 characters.", "blue");
                    return;
                }
                state.user.username = username;
                state.user.referralCode = "KAI-" + username.toUpperCase() + "-" + Math.floor(1000 + Math.random() * 9000);
            }

            state.onboardingStep += 1;
            updateOnboardingView();
        }

        function prevStep() {
            if (state.onboardingStep > 1) {
                state.onboardingStep -= 1;
                updateOnboardingView();
            }
        }

        // Onboarding actions helpers
        function simulateWalletConnect(walletType) {
            // Generate a fake cryptographic address matching network standards
            let prefix = "0x";
            if (walletType === 'Solana') prefix = "7x";
            if (walletType === 'Sui') prefix = "0xSui";
            
            const randomHash = Array.from({length: 24}, () => Math.floor(Math.random()*16).toString(16)).join('');
            const address = `${prefix}${randomHash.substring(0, 6)}...${randomHash.substring(18)}`;
            
            state.user.walletAddress = address;
            state.walletConnected = true;

            // Update onboarding elements
            document.getElementById('wallet-connected-display').classList.remove('hidden');
            document.getElementById('connected-wallet-address').innerText = `${walletType} [${address}]`;
            
            showToast("Wallet Synced", `Successfully handshaked with ${walletType} Node address!`, "gold");
        }

        function connectSocial(socialType) {
            state.user[`${socialType}Connected`] = true;
            const btn = document.getElementById(`social-btn-${socialType}`);
            btn.innerHTML = `<i class="fa-solid fa-circle-check"></i> Connected`;
            btn.className = "px-4 py-1.5 rounded bg-emerald-500 text-hiveDark-900 font-bold text-xs";
            
            showToast("Pipeline Synchronized", `${socialType.toUpperCase()} alerts stream established.`, "blue");
        }

        function updateReferralCodePreview() {
            const username = document.getElementById('ob-username').value.trim() || "USERNAME";
            const previewText = `https://kinngs.ai/join?ref=KAI-${username.toUpperCase()}`;
            document.getElementById('ref-code-preview').innerText = previewText;
        }

        function copyReferralLink() {
            const text = document.getElementById('ref-code-preview').innerText;
            // Native fallback for iframe container context
            const el = document.createElement('textarea');
            el.value = text;
            document.body.appendChild(el);
            el.select();
            document.execCommand('copy');
            document.body.removeChild(el);

            showToast("Copied to Clipboard", "Your unique node invitation link was copied.", "gold");
        }

        function runVaultInitialization() {
            const bar = document.getElementById('init-loader-progress');
            bar.style.width = "100%";

            setTimeout(() => {
                // Onboarding complete, migrate to dashboard
                showToast("Node Deployed!", "Ecosystem Control Chamber active.", "gold");
                // Enable navbar indicator badge
                document.getElementById('user-badge').classList.remove('hidden');
                document.getElementById('badge-username').innerText = state.user.username.toUpperCase();
                document.getElementById('badge-balance').innerText = `${state.balance} $KNGS`;

                // Update UI button state
                const actionBtn = document.getElementById('nav-action-btn');
                actionBtn.innerHTML = `<i class="fa-solid fa-gauge"></i> Enter Hive`;
                actionBtn.onclick = function() { navigate('dashboard'); };

                navigate('dashboard');
            }, 3000);
        }

        // Dashboard State Render updates
        function updateDashboardView() {
            document.getElementById('dash-balance').innerText = `${state.balance} $KNGS`;
            document.getElementById('badge-balance').innerText = `${state.balance} $KNGS`;
            document.getElementById('dash-multiplier').innerText = `${state.boosterMultiplier.toFixed(1)}x Active`;
            document.getElementById('dash-referrals').innerText = `${state.referralsCount} nodes`;
            document.getElementById('companion-username').innerText = state.user.username;
        }

        // Interactive Quest Completion Handlers
        function completeQuest(questId) {
            if (questId === 'twitter') {
                if (state.completedQuests.twitter) return;
                state.completedQuests.twitter = true;
                state.balance += 50;
                
                const btn = document.getElementById('q-btn-twitter');
                btn.className = "px-4 py-1.5 rounded bg-emerald-500 text-hiveDark-900 font-bold text-xs pointer-events-none";
                btn.innerHTML = `<i class="fa-solid fa-circle-check"></i> Secured`;
                
                showToast("Quest Complete", "Claimed 50 $KNGS tokens instantly!", "gold");
            }

            if (questId === 'discord') {
                if (state.completedQuests.discord) return;
                state.completedQuests.discord = true;
                state.balance += 75;
                
                const btn = document.getElementById('q-btn-discord');
                btn.className = "px-4 py-1.5 rounded bg-emerald-500 text-hiveDark-900 font-bold text-xs pointer-events-none";
                btn.innerHTML = `<i class="fa-solid fa-circle-check"></i> Secured`;
                
                showToast("Quest Complete", "Claimed 75 $KNGS tokens instantly!", "gold");
            }

            if (questId === 'zealy') {
                if (state.completedQuests.zealy) return;
                state.completedQuests.zealy = true;
                state.boosterMultiplier += 0.1;
                
                const btn = document.getElementById('q-btn-zealy');
                btn.className = "px-4 py-1.5 rounded bg-emerald-500 text-hiveDark-900 font-bold text-xs pointer-events-none";
                btn.innerHTML = `<i class="fa-solid fa-circle-check"></i> Connected`;
                
                showToast("Multiplier Synced", "Ecosystem booster rate increased by +0.1x!", "blue");
            }

            updateDashboardView();
        }

        // KB Drone console actions
        function droneAction(actionType) {
            const logsBox = document.getElementById('drone-log-box');
            const batteryEl = document.getElementById('drone-battery');
            const statusEl = document.getElementById('drone-status');
            const altitudeEl = document.getElementById('drone-altitude');

            const now = new Date().toLocaleTimeString();

            if (actionType === 'scan') {
                state.droneState.status = "SCANNING";
                statusEl.className = "font-bold text-cyberBlue-400 block animate-pulse";
                statusEl.innerText = "SCANNING REGION";

                const log1 = `[${now}] [RADAR]: Sweeping local coordinates. Zero threats found.`;
                const log2 = `[${now}] [BIO-RADAR]: Detected health rate optimal for linked node.`;
                
                state.droneState.logs.push(log1, log2);
                logsBox.innerHTML += `<div>${log1}</div><div>${log2}</div>`;
                showToast("KB Scanning", "Biometric atmospheric sweep active.", "blue");
            }

            if (actionType === 'charge') {
                state.droneState.battery = 100;
                batteryEl.innerText = "100% (Solar Maxed)";
                
                const log = `[${now}] [BATTERY]: Active solar-charging loop fully charged cells.`;
                state.droneState.logs.push(log);
                logsBox.innerHTML += `<div>${log}</div>`;
                showToast("KB Synchronized", "Solar cell charging loops fully refreshed.", "gold");
            }

            if (actionType === 'log') {
                // Generate a full technical block dump
                const dump = `[${now}] [TELEMETRY_DUMP]: Context encryption status: SECURE. E2E Sync: OK. Multichain token generation: ACTIVE.`;
                state.droneState.logs.push(dump);
                logsBox.innerHTML += `<div class="text-kingGold-300 font-semibold">${dump}</div>`;
                showToast("Console Log Outputted", "Active operational records parsed to local frame.", "blue");
            }

            logsBox.scrollTop = logsBox.scrollHeight;
        }

        function simulateDroneTelemetry() {
            if (state.currentTab !== 'dashboard') return;

            // Simulating active telemetry fluctuating
            const batteryEl = document.getElementById('drone-battery');
            const altitudeEl = document.getElementById('drone-altitude');
            
            if (state.droneState.battery > 10) {
                state.droneState.battery -= 1;
                batteryEl.innerText = `${state.droneState.battery}% (Solar Core)`;
            }

            const altDelta = (Math.random() * 2 - 1).toFixed(1);
            state.droneState.altitude = (parseFloat(state.droneState.altitude) + parseFloat(altDelta)).toFixed(1);
            if (state.droneState.altitude < 2) state.droneState.altitude = 5.0;
            altitudeEl.innerText = `${state.droneState.altitude}m`;
        }

        // Custom Notification Toast Display system
        function showToast(title, body, colorScheme) {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            
            let colorClasses = "bg-hiveDark-850 border-kingGold-500/30 text-kingGold-400";
            let icon = `<i class="fa-solid fa-crown text-kingGold-400"></i>`;
            
            if (colorScheme === "blue") {
                colorClasses = "bg-hiveDark-850 border-cyberBlue-500/30 text-cyberBlue-400";
                icon = `<i class="fa-solid fa-sparkles text-cyberBlue-400"></i>`;
            }

            toast.className = `p-4 rounded-xl border ${colorClasses} shadow-dualGlow flex items-start gap-3 transform transition-all duration-300 translate-x-12 opacity-0 pointer-events-auto`;
            toast.innerHTML = `
                <div class="text-lg shrink-0">${icon}</div>
                <div>
                    <h5 class="font-futuristic font-bold text-sm text-slate-100 uppercase leading-none">${title}</h5>
                    <p class="text-xs text-slate-400 mt-1 leading-normal">${body}</p>
                </div>
            `;

            container.appendChild(toast);
            
            // Animate In
            setTimeout(() => {
                toast.classList.remove('translate-x-12', 'opacity-0');
            }, 50);

            // Animate Out & Destroy
            setTimeout(() => {
                toast.classList.add('translate-x-12', 'opacity-0');
                setTimeout(() => {
                    toast.remove();
                }, 300);
            }, 4500);
        }

        // Dynamic Time tracker
        function updateTimestamp() {
            const now = new Date();
            const dateStr = now.toLocaleDateString();
            const timeStr = now.toLocaleTimeString();
            
            const timestampEl = document.getElementById('drone-timestamp');
            if (timestampEl) {
                timestampEl.innerText = `${dateStr} ${timeStr}`;
            }
        }

        // SANDBOX CONVERSATIONAL TERMINAL ENGINE (MOCK)
        const KAI_KNOWLEDGE_BASE = {
            "mission": "The core mission of KINNGS AI Network is: 'To richly increase and improve human productivity through deeply personalized artificial intelligence.' It guiding users to become their best versions mentally, emotionally, and socially.",
            "privacy": "Privacy is sacred to KINNGS. All telemetry, voice profiles, and data are dual-encrypted. All processing happens on local devices and private, decentralized cloud chains. No external entity can tap into your metrics.",
            "drone": "The KB (Kinngs Bee) Drones are autonomous solar-recharged robotic assistants. They act as guardians executing atmospheric hazard checks, health metrics processing, and local safety patrol.",
            "token": "The $KINNGS token economy drives the ecosystem. Phase 1 lets you earn simulated tokens and multipliers by joining the whitelist, while Phase 2 and 3 introduce Genesis NFTs and the finalized multi-chain mainnet $KNGS token.",
            "hive": "The Hive is your personalized master control chamber. It unifies all biometric statistics, local cryptographic assets, memories archives, drone logs, and active habits tracking."
        };

        function quickPrompt(promptText) {
            document.getElementById('sandbox-input').value = promptText;
            sendSandboxMessage();
        }

        function sendSandboxMessage() {
            const inputEl = document.getElementById('sandbox-input');
            const query = inputEl.value.trim();
            if (!query) return;

            const chatSpace = document.getElementById('sandbox-messages');
            
            // Render user message
            const userMsg = document.createElement('div');
            userMsg.className = "flex gap-3 max-w-[85%] ml-auto justify-end";
            userMsg.innerHTML = `
                <div class="p-4 rounded-2xl bg-hiveDark-800 border border-white/5 text-sm text-slate-200 leading-relaxed">
                    ${query}
                </div>
            `;
            chatSpace.appendChild(userMsg);
            inputEl.value = "";
            chatSpace.scrollTop = chatSpace.scrollHeight;

            // Generate intelligent AI response
            setTimeout(() => {
                let reply = "That is a fascinating inquiry. My cognitive pathways are fine-tuning dynamically to handle deep personalization. Whitelist contributors will shape our core algorithms. Secure your node profile to start deep training!";
                
                const queryLower = query.toLowerCase();
                if (queryLower.includes('mission') || queryLower.includes('goal')) {
                    reply = KAI_KNOWLEDGE_BASE.mission;
                } else if (queryLower.includes('privacy') || queryLower.includes('secure') || queryLower.includes('encrypt')) {
                    reply = KAI_KNOWLEDGE_BASE.privacy;
                } else if (queryLower.includes('drone') || queryLower.includes('kb') || queryLower.includes('bee')) {
                    reply = KAI_KNOWLEDGE_BASE.drone;
                } else if (queryLower.includes('token') || queryLower.includes('coin') || queryLower.includes('kngs')) {
                    reply = KAI_KNOWLEDGE_BASE.token;
                } else if (queryLower.includes('hive') || queryLower.includes('control') || queryLower.includes('dashboard')) {
                    reply = KAI_KNOWLEDGE_BASE.hive;
                }

                const botMsg = document.createElement('div');
                botMsg.className = "flex gap-3 max-w-[85%]";
                botMsg.innerHTML = `
                    <div class="h-8 w-8 rounded-lg bg-kingGold-500/10 border border-kingGold-500/20 flex items-center justify-center text-kingGold-400 text-sm shrink-0">
                        <i class="fa-solid fa-brain-circuit"></i>
                    </div>
                    <div class="p-4 rounded-2xl bg-hiveDark-850 border border-white/5 text-sm text-slate-200 leading-relaxed">
                        ${reply}
                    </div>
                `;
                chatSpace.appendChild(botMsg);
                chatSpace.scrollTop = chatSpace.scrollHeight;
            }, 750);
        }

        // COMPANION PRIVATE TERMINAL ENGINE (MOCK)
        function sendDashMessage() {
            const inputEl = document.getElementById('dash-input');
            const query = inputEl.value.trim();
            if (!query) return;

            const chatSpace = document.getElementById('dash-messages');
            
            // User message
            const userMsg = document.createElement('div');
            userMsg.className = "flex gap-2 justify-end";
            userMsg.innerHTML = `
                <div class="p-3 rounded-xl bg-hiveDark-800 text-slate-200 border border-white/5">
                    ${query}
                </div>
            `;
            chatSpace.appendChild(userMsg);
            inputEl.value = "";
            chatSpace.scrollTop = chatSpace.scrollHeight;

            // Response
            setTimeout(() => {
                const botMsg = document.createElement('div');
                botMsg.className = "flex gap-2";
                botMsg.innerHTML = `
                    <div class="p-3 rounded-xl bg-hiveDark-900 text-kingGold-300 border border-kingGold-500/15">
                        <span class="font-bold text-cyberBlue-400 mr-1">KAI:</span> Secure memory indexed. I have logged this pattern in your local database vault. Continuous productivity boosts scheduled!
                    </div>
                `;
                chatSpace.appendChild(botMsg);
                chatSpace.scrollTop = chatSpace.scrollHeight;
            }, 600);
        }
    </script>
</body>
</html>

```
