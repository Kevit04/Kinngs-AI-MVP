                                </div>
                            </div>

                            <!-- Messaging content Area -->
                            <div id="dash-messages" class="space-y-3 overflow-y-auto pr-1 max-h-[220px] text-xs">
                                <div class="flex gap-2">
                                    <div class="p-3 rounded-xl bg-hiveDark-900 text-slate-300 leading-relaxed border border-white/5">
                                        Vault connection authenticated! Welcome back, <span class="text-kingGold-400 font-bold" id="companion-username">User</span>. Your cognitive metrics are exceptional today. Focus parameters set. Inquire or command me.
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Chat Input Block -->
                        <div class="space-y-3 pt-3">
                            <div class="flex gap-1.5">
                                <input id="dash-input" type="text" placeholder="Engage custom cognitive prompt..." class="flex-grow bg-hiveDark-900 border border-white/10 rounded-xl px-3 py-2 text-xs text-slate-200 placeholder:text-slate-500 focus:outline-none focus:border-kingGold-500" onkeydown="if(event.key === 'Enter') sendDashMessage()">
                                <button onclick="sendDashMessage()" class="px-4 py-2 rounded-xl bg-gradient-to-r from-kingGold-600 to-kingGold-500 text-hiveDark-900 font-bold text-xs">
                                    <i class="fa-solid fa-paper-plane"></i>
                                </button>
                            </div>
                            <!-- Memory status badge -->
                            <div class="flex items-center justify-between text-[10px] text-slate-500">
                                <span><i class="fa-solid fa-database mr-1"></i> Data stored locally + cloud</span>
                                <span class="text-cyberBlue-400"><i class="fa-solid fa-circle-check"></i> E2E Encrypted</span>
                            </div>
                        </div>

                    </div>
                </div>

            </div>
        </div>

    </main>

    <!-- FOOTER SECTION -->
    <footer class="glass-panel border-t border-white/5 py-8 mt-12 px-4 lg:px-12">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
            <div class="flex items-center gap-3">
                <span class="text-sm font-futuristic text-slate-500 tracking-[0.2em] uppercase">For You. With You. Always. — Kinngs AI</span>
